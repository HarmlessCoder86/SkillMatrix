# Domain for Caddy SSL (production only)
DOMAIN=skills.yourdomain.com

# PostgreSQL
POSTGRES_DB=skill_matrix
POSTGRES_USER=skillmatrix
POSTGRES_PASSWORD=CHANGE_ME_TO_SOMETHING_SECURE

# JWT Secret (required — generate with: openssl rand -hex 32)
JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# CORS Origins (comma-separated, for production set to your domain)
CORS_ORIGINS=https://skills.yourdomain.com

# Frontend build arg (leave as /api for production)
VITE_API_URL=/api
